# ==============================================================================
#                 Omni-IPS Configuration Parameters (Example)
# ==============================================================================
# Copy this file to '.env' and fill in your custom configurations.

# FastAPI Server Config
HOST=0.0.0.0
PORT=8080

# Neo4j Database Config
# Use bolt://localhost:7687 for local host development, and bolt://neo4j:7687 inside Docker
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=omni_ips_password

# Chroma Vector DB Config
# Use localhost for local host development, and chromadb inside Docker
CHROMADB_HOST=localhost
CHROMADB_PORT=8000

# LangChain / OpenAI Configuration (Optional, falls back to offline templates if empty)
OPENAI_API_KEY=your_openai_api_key_here
